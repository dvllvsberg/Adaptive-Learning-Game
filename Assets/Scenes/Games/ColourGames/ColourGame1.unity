  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3066d1ac12187a342b57aa4649b9fac8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  helpPanel: {fileID: 1415984563}
  titleText: {fileID: 1162953949}
  bodyText: {fileID: 526214485}
  pageCounterText: {fileID: 1570663482}
  previousButton: {fileID: 1878660198}
  nextButton: {fileID: 623162172}
  pages:
  - titleKey: help.colour.1.page1.title
    bodyKey: help.colour.1.page1.body
    title: "\u041E \u043C\u0438\u043D\u0438-\u0438\u0433\u0440\u0435 \" Colour Game
      1\""
    body: "\u0414\u0430\u043D\u043D\u0430\u044F \u043C\u0438\u043D\u0438-\u0438\u0433\u0440\u0430
      \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430 \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
      \u043A\u043E\u0433\u043D\u0438\u0442\u0438\u0432\u043D\u044B\u0445 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439
      \u0440\u0435\u0431\u0435\u043D\u043A\u0430 \u0447\u0435\u0440\u0435\u0437 \u0440\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u0432\u0430\u043D\u0438\u0435
      \u0446\u0432\u0435\u0442\u043E\u0432 \u0438 \u0432\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u044B\u0445
      \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u043E\u0432 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432.\r\n\r\n\u0412
      \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u043F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
      \u0442\u0440\u0435\u043D\u0438\u0440\u0443\u044E\u0442\u0441\u044F:\r\n\r\n~
      \u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u044F \u0438
      \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F;\r\n~
      \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
      \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u044F;\r\n~ \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C
      \u0432\u044B\u0431\u043E\u0440\u0430 \u043F\u043E \u0443\u0441\u043B\u043E\u0432\u0438\u044E;\r\n~
      \u0431\u0430\u0437\u043E\u0432\u044B\u0435 \u043D\u0430\u0432\u044B\u043A\u0438
      \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u043E\u0432.\r\n\n\u0418\u0433\u0440\u0430
      \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0430 \u043F\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0443
      \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E\u0433\u043E \u0443\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u0438\u044F,
      \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u043C\u044F\u0433\u043A\u043E
      \u043F\u043E\u0432\u044B\u0448\u0430\u0442\u044C \u043D\u0430\u0433\u0440\u0443\u0437\u043A\u0443
      \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
      \u043E\u0431\u0443\u0447\u0430\u044E\u0449\u0438\u0439 \u044D\u0444\u0444\u0435\u043A\u0442."
  - titleKey: help.colour.1.page2.title
    bodyKey: help.colour.1.page2.body
    title: "\u041A\u0430\u043A \u0438\u0433\u0440\u0430\u0442\u044C"
    body: "\u041F\u0440\u0430\u0432\u0438\u043B\u0430 \u043F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F:\n\r\n1.
      \u0412 \u0432\u0435\u0440\u0445\u043D\u0435\u0439 \u0447\u0430\u0441\u0442\u0438
      \u044D\u043A\u0440\u0430\u043D\u0430 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044F
      \u0437\u0430\u0434\u0430\u043D\u0438\u0435 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440:
      \"\u0412\u044B\u0431\u0435\u0440\u0438: \u0416\u0435\u043B\u0442\u044B\u0439\").\r\n2.
      \u041D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0432\u044B\u0431\u0440\u0430\u0442\u044C
      \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u0443\u044E \u0444\u0438\u0433\u0443\u0440\u0443
      \u0441\u0440\u0435\u0434\u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445
      \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432.\r\n3. \u041F\u0440\u0438
      \u0432\u0435\u0440\u043D\u043E\u043C \u043E\u0442\u0432\u0435\u0442\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u043A\u043D\u043E\u043F\u043A\u0430 \"Next\" \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430
      \u043A \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C\u0443 \u0443\u0440\u043E\u0432\u043D\u044E.\r\n4.
      \u041D\u0430 \u0443\u0440\u043E\u0432\u043D\u044F\u0445 1-5 \u0432\u044B\u0431\u043E\u0440
      \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F \u043F\u043E
      \u0446\u0432\u0435\u0442\u0443.\r\n5. \u041D\u0430 \u0443\u0440\u043E\u0432\u043D\u044F\u0445
      6-10 \u0432\u044B\u0431\u043E\u0440 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F
      \u043F\u043E \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0438 \u0446\u0432\u0435\u0442
      + \u0444\u043E\u0440\u043C\u0430 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440:
      \"\u041A\u0440\u0430\u0441\u043D\u044B\u0439 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\").\r\n\u0426\u0435\u043B\u044C
      \u0438\u0433\u0440\u043E\u043A\u0430 \u2014 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E
      \u043F\u0440\u043E\u0439\u0442\u0438 \u0432\u0441\u0435 \u0443\u0440\u043E\u0432\u043D\u0438,
      \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044F \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C
      \u0438 \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C."
