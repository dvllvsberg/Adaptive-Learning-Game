--- !u!114 &1798673059
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1798673058}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3066d1ac12187a342b57aa4649b9fac8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  helpPanel: {fileID: 1967571482}
  titleText: {fileID: 1986066114}
  bodyText: {fileID: 1128605668}
  pageCounterText: {fileID: 597358094}
  previousButton: {fileID: 1293539211}
  nextButton: {fileID: 103596649}
  panelFadeDuration: 0.18
  pages:
  - titleKey: help.colour.select.page1.title
    bodyKey: help.colour.select.page1.body
    title: "\u0420\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u0432\u0430\u043D\u0438\u0435
      \u0426\u0432\u0435\u0442\u043E\u0432"
    body: " `\u042D\u0442\u043E\u0442 \u0440\u0430\u0437\u0434\u0435\u043B \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0435\u0442
      \u0440\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u0432\u0430\u043D\u0438\u0435
      \u0446\u0432\u0435\u0442\u043E\u0432 \u0438 \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
      \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435. \u0420\u0435\u0431\u0435\u043D\u043E\u043A
      \u0443\u0447\u0438\u0442\u0441\u044F:\r\n\r\n\u0440\u0430\u0437\u043B\u0438\u0447\u0430\u0442\u044C
      \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0446\u0432\u0435\u0442\u0430;\r\n\u0431\u044B\u0441\u0442\u0440\u0435\u0435
      \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u043D\u0443\u0436\u043D\u044B\u0439
      \u0446\u0432\u0435\u0442 \u0441\u0440\u0435\u0434\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432;\r\n\u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
      \u0444\u043E\u043A\u0443\u0441 \u043D\u0430 \u0437\u0430\u0434\u0430\u043D\u0438\u0438.\r\n\u0418\u0433\u0440\u044B
      \u043D\u0430 \u0446\u0432\u0435\u0442\u0430 \u043F\u043E\u043C\u043E\u0433\u0430\u044E\u0442
      \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044C \u043A\u043E\u0433\u043D\u0438\u0442\u0438\u0432\u043D\u044B\u0435
      \u043D\u0430\u0432\u044B\u043A\u0438: \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435,
      \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u044F,
      \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0432\u044B\u0431\u043E\u0440\u0430.`"
