  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u042D\u0442\u043E \u043E\u0431\u0443\u0447\u0430\u044E\u0449\u0430\u044F
    \u0438\u0433\u0440\u0430 \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F
    \u043A\u043E\u0433\u043D\u0438\u0442\u0438\u0432\u043D\u044B\u0445 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439.\n\n\u041D\u0430\u0432\u044B\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u044E\u0442\u0441\u044F:\r\n-
    \u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435\r\n- \u041F\u0430\u043C\u044F\u0442\u044C\r\n-
    \u041B\u043E\u0433\u0438\u043A\u0430\r\n\n\u041C\u0438\u043D\u0438-\u0438\u0433\u0440\u044B:\r\n1)
    \u0418\u0433\u0440\u0430 \u043D\u0430 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u2014 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u043D\u0443\u0436\u043D\u044B\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B/\u0441\u0438\u043C\u0432\u043E\u043B\u044B
    \u0437\u0430 \u0432\u0440\u0435\u043C\u044F.\r\n2) \u0418\u0433\u0440\u0430 \u043D\u0430
    \u043F\u0430\u043C\u044F\u0442\u044C \u2014 \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0442\u044C
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0442\u044C \u0438\u0445.\r\n3)
    \u0418\u0433\u0440\u0430 \u043D\u0430 \u043B\u043E\u0433\u0438\u043A\u0443 \u2014
    \u0440\u0435\u0448\u0430\u0442\u044C \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438."
  m_isRightToLeft: 0
